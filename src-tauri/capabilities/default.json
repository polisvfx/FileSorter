{
  "identifier": "default",
  "description": "Default capabilities for FileSorter",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "shell:allow-open",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" }
      ]
    }
  ]
}
